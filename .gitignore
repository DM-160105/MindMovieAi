# ── Movie Recommender — Modern .gitignore ─────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.venv
venv/
ENV/
*.bak
*.swp

# Next.js / Frontend
node_modules/
.next/
out/
build/
dist/
.cache/
.npm
.yarn
.pnpm-store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.vercel

# Python Packaging / Distribution
.Python
develop-eggs/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Unit test / Coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# IDEs / Editors
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ML Artifacts & Data
backend/artifacts/movies.index
backend/artifacts/movie_dict.pkl
backend/data/youtube_dataset/*.csv
backend/data/tmdb_dataset/*.csv
*.pkl
*.h5
*.joblib

# Secrets & Configs
configs/secrets.yaml
*.pem
*.key

# Agent Infrastructure
.gemini/
.agents/
.agent/
brain/
implementation_plan.md
task.md
walkthrough.md
